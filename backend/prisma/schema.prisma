datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model District {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  code           String?
  complaints     Complaint[]
  womenSafety   WomenSafety[]
  cCTNSComplaint CCTNSComplaint[]
  offices        Office[]
  createdAt     DateTime        @default(now())
}

model Complaint {
  id                  Int        @id @default(autoincrement())
  complRegNum         String?    @unique
  districtId          Int?
  district            District?  @relation(fields: [districtId], references: [id])
  complDesc           String?
  complSrno          String?
  complRegDt         DateTime?
  firstName           String?
  lastName            String?
  mobile              String?
  gender              String?
  age                 Int?
  addressLine1         String?
  addressLine2        String?
  addressLine3        String?
  village             String?
  tehsil              String?
  addressDistrict     String?
  addressPs          String?
  receptionMode      String?
  incidentType       String?
  incidentPlc       String?
  incidentFromDt    DateTime?
  incidentToDt      DateTime?
  classOfIncident    String?
  respondentCategories String?
  complaintSource   String?
  typeOfComplaint   String?
  complainantType   String?
  complaintPurpose  String?
  statusOfComplaint String?
  disposalDate     DateTime?
  ioDetails        String?
  branch           String?
  firNumber         String?
  actionTaken      String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model WomenSafety {
  id                 Int        @id @default(autoincrement())
  complRegNum        String?    @unique
  districtId         Int?
  district           District?   @relation(fields: [districtId], references: [id])
  complDesc          String?
  complRegDt        DateTime?
  firstName         String?
  lastName          String?
  mobile            String?
  gender            String?
  age                Int?
  addressLine1      String?
  addressLine2     String?
  addressLine3     String?
  village           String?
  tehsil            String?
  incidentType     String?
  incidentPlc     String?
  incidentFromDt   DateTime?
  incidentToDt    DateTime?
  complaintSource  String?
  statusOfComplaint String?
  disposalDate    DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model CCTNSComplaint {
  id                Int        @id @default(autoincrement())
  complRegNum      String?    @unique
  districtId       Int?
  district         District?  @relation(fields: [districtId], references: [id])
  compCategory     String?
  psrNumber        String?
  firNumber        String?
  firDate          DateTime?
  ActSection       String?
  accusedName     String?
  accusedAge      Int?
  accusedAddress  String?
  victimName      String?
  incidentDate   DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Office {
  id          Int          @id @default(autoincrement())
  name        String
  code        String?
  districtId  Int?
  district    District?    @relation(fields: [districtId], references: [id])
  createdAt   DateTime     @default(now())
}

model District_Master {
  id             BigInt    @id
  DistrictName   String    @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model PoliceStation_Master {
  id             BigInt    @id
  Name           String
  DistrictID     BigInt
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Offices_Master {
  id             BigInt    @id
  Name           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model NatureOfComplaint {
  id               Int      @id @default(autoincrement())
  natureComplaints String?  @map("nature_complaints")

  @@map("tb_nature_complaints")
}

model ReceivedFrom {
  id             Int      @id @default(autoincrement())
  receivedFrom   String?  @map("recieved_from")

  @@map("tb_received_from")
}